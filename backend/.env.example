# MongoDB Connection String (from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/mentorbridge?retryWrites=true&w=majority

# JWT Secret for token signing (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_here_at_least_32_chars_minimum

# Server Port
PORT=5000

# Frontend URL (for CORS)
# Local: http://localhost:5173
# Production: https://your-vercel-url.vercel.app
CLIENT_URL=http://localhost:5173

# Environment
# development or production
NODE_ENV=development
